rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }
    
    function hasRole(role) {
      let data = getUserData();
      return isSignedIn() && data != null && data.get('role', '') == role;
    }
    
    function isAdmin() {
      return hasRole('Admin');
    }
    
    function isPharmacist() {
      let data = getUserData();
      return isSignedIn() && data != null && (data.get('role', '') == 'Pharmacist' || data.get('role', '') == 'Admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (isAdmin() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])));
    }

    // Medicines collection
    match /medicines/{medicineId} {
      allow read: if isSignedIn();
      allow write: if isPharmacist();
    }

    // Sales collection
    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Purchases collection
    match /purchases/{purchaseId} {
      allow read: if isPharmacist();
      allow write: if isPharmacist();
    }

    // Suppliers collection
    match /suppliers/{supplierId} {
      allow read: if isPharmacist();
      allow write: if isPharmacist();
    }
  }
}
